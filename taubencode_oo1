<script>
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');
const overlay = document.getElementById('overlay');
const panel = document.getElementById('panel');
const scoreEl = document.getElementById('score');
const bestEl = document.getElementById('best');
const musicBtn = document.getElementById('musicBtn');

const WIDTH = canvas.width;
const HEIGHT = canvas.height;
const GROUND = 322;

const NORMAL_GRAVITY = 0.92;
const GLIDE_GRAVITY = 0.16;
const JUMP_POWER = -10.5;
const FLAP_LIFT = -0.22;
const MAX_GLIDE_FALL = 1.35;

const START_SPEED = 2.3;
const SPEED_GAIN = 0.00045;

let running = false;
let gameOver = false;
let hold = false;
let score = 0;
let best = Number(localStorage.getItem('tauben_deluxe_best') || 0);
let frame = 0;
let speed = START_SPEED;
let obstacleTimer = 105;
let nearOffset = 0;
let midOffset = 0;
let groundOffset = 0;
let flash = 0;
let musicEnabled = false;

bestEl.textContent = best;

const pigeon = {
  x: 138,
  y: GROUND - 44,
  vy: 0,
  wingPhase: 0,
  headPhase: 0,
  runPhase: 0,
  tilt: 0,
  flapBoost: 0
};

const obstacles = [];
const clouds = [
  {x:120,y:62,s:1.1},
  {x:380,y:95,s:0.9},
  {x:640,y:58,s:1.2},
  {x:840,y:88,s:0.8}
];

const midBuildings = [
  {x:0,w:90,h:90},
  {x:130,w:120,h:130},
  {x:280,w:95,h:105},
  {x:410,w:150,h:150},
  {x:590,w:125,h:100},
  {x:760,w:110,h:120},
  {x:930,w:100,h:85},
  {x:1080,w:130,h:145}
];

const nearBuildings = [
  {x:30,w:120,h:110},
  {x:210,w:100,h:150},
  {x:360,w:160,h:125},
  {x:580,w:120,h:175},
  {x:760,w:135,h:135},
  {x:960,w:150,h:160},
  {x:1170,w:125,h:115}
];

let audioCtx = null;
let musicNodes = null;
let musicPulse = 0;

function ensureAudio(){
  if(!audioCtx){
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
  if(audioCtx.state === 'suspended'){
    audioCtx.resume();
  }
}

function jumpSound(){
  ensureAudio();
  const t = audioCtx.currentTime;

  const osc1 = audioCtx.createOscillator();
  const osc2 = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  const filter = audioCtx.createBiquadFilter();

  filter.type = 'lowpass';
  filter.frequency.setValueAtTime(1300, t);

  osc1.type = 'square';
  osc2.type = 'triangle';
  osc1.frequency.setValueAtTime(820, t);
  osc1.frequency.exponentialRampToValueAtTime(520, t + 0.08);
  osc2.frequency.setValueAtTime(330, t);
  osc2.frequency.exponentialRampToValueAtTime(220, t + 0.09);

  gain.gain.setValueAtTime(0.0001, t);
  gain.gain.exponentialRampToValueAtTime(0.035, t + 0.01);
  gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.11);

  osc1.connect(filter);
  osc2.connect(filter);
  filter.connect(gain);
  gain.connect(audioCtx.destination);

  osc1.start(t);
  osc2.start(t);
  osc1.stop(t + 0.12);
  osc2.stop(t + 0.12);
}

function flapWhisper(){
  if(!musicEnabled) return;
  ensureAudio();
  const t = audioCtx.currentTime;
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  const filter = audioCtx.createBiquadFilter();
  osc.type = 'sine';
  osc.frequency.setValueAtTime(220, t);
  osc.frequency.exponentialRampToValueAtTime(180, t + 0.12);
  filter.type = 'lowpass';
  filter.frequency.setValueAtTime(700, t);
  gain.gain.setValueAtTime(0.0001, t);
  gain.gain.exponentialRampToValueAtTime(0.012, t + 0.01);
  gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.14);
  osc.connect(filter);
  filter.connect(gain);
  gain.connect(audioCtx.destination);
  osc.start(t);
  osc.stop(t + 0.15);
}

function setMusic(enabled){
  musicEnabled = enabled;
  musicBtn.textContent = enabled ? 'Musik: an' : 'Musik: aus';
  musicBtn.classList.toggle('active', enabled);
  ensureAudio();

  if(enabled){
    if(!musicNodes){
      const master = audioCtx.createGain();
      master.gain.value = 0.03;
      master.connect(audioCtx.destination);

      const pad1 = audioCtx.createOscillator();
      const pad2 = audioCtx.createOscillator();
      const pad3 = audioCtx.createOscillator();
      const padGain = audioCtx.createGain();
      const lfo = audioCtx.createOscillator();
      const lfoGain = audioCtx.createGain();
      const filter = audioCtx.createBiquadFilter();

      pad1.type = 'sine';
      pad2.type = 'triangle';
      pad3.type = 'sine';
      pad1.frequency.value = 196;
      pad2.frequency.value = 246.94;
      pad3.frequency.value = 293.66;

      filter.type = 'lowpass';
      filter.frequency.value = 900;

      padGain.gain.value = 0.45;

      lfo.type = 'sine';
      lfo.frequency.value = 0.22;
      lfoGain.gain.value = 0.12;

      lfo.connect(lfoGain);
      lfoGain.connect(padGain.gain);

      pad1.connect(filter);
      pad2.connect(filter);
      pad3.connect(filter);
      filter.connect(padGain);
      padGain.connect(master);

      pad1.start();
      pad2.start();
      pad3.start();
      lfo.start();

      musicNodes = {master, pad1, pad2, pad3, padGain, filter, lfo};
    }
    musicNodes.master.gain.cancelScheduledValues(audioCtx.currentTime);
    musicNodes.master.gain.setTargetAtTime(0.032, audioCtx.currentTime, 0.2);
  } else if(musicNodes){
    musicNodes.master.gain.cancelScheduledValues(audioCtx.currentTime);
    musicNodes.master.gain.setTargetAtTime(0.0001, audioCtx.currentTime, 0.15);
  }
}

musicBtn.addEventListener('click', () => setMusic(!musicEnabled));

function showStartPanel(){
  overlay.style.display = 'flex';
  panel.innerHTML = `
    <div style="font-size:30px">🐦</div>
    <h2>Taubenlauf Deluxe</h2>
    <p>Starten und dann in der Luft gedrückt halten, damit die Taube segelt statt wie ein Stein vom Amt zu fallen.</p>
    <button id="startBtn">Spiel starten</button>
  `;
  document.getElementById('startBtn').onclick = startGame;
}

function showGameOverPanel(){
  overlay.style.display = 'flex';
  panel.innerHTML = `
    <div style="font-size:30px">💥🐦</div>
    <h2>Taube kollidierte mit Großstadtwirklichkeit</h2>
    <p>Punkte: <b>${score}</b>. Rekord: <b>${best}</b>. Die Infrastruktur war erneut taubenfeindlich.</p>
    <button id="restartBtn">Nochmal gurren</button>
  `;
  document.getElementById('restartBtn').onclick = resetGame;
}

function resetGame(){
  running = false;
  gameOver = false;
  hold = false;
  score = 0;
  frame = 0;
  speed = START_SPEED;
  obstacleTimer = 105;
  nearOffset = 0;
  midOffset = 0;
  groundOffset = 0;
  flash = 0;
  pigeon.y = GROUND - 44;
  pigeon.vy = 0;
  pigeon.wingPhase = 0;
  pigeon.headPhase = 0;
  pigeon.runPhase = 0;
  pigeon.tilt = 0;
  pigeon.flapBoost = 0;
  obstacles.length = 0;
  scoreEl.textContent = '0';
  showStartPanel();
}

function startGame(){
  ensureAudio();
  overlay.style.display = 'none';
  running = true;
  gameOver = false;
}

function spawnObstacle(){
  const roll = Math.random();
  if(roll > 0.72){
    obstacles.push({kind:'cat', x:WIDTH + 30, y:GROUND - 54, w:46, h:54});
  } else if(roll > 0.38){
    obstacles.push({kind:'cone', x:WIDTH + 30, y:GROUND - 40, w:24, h:40});
  } else {
    obstacles.push({kind:'bag', x:WIDTH + 30, y:GROUND - 32, w:36, h:32});
  }
  obstacleTimer = 90 + Math.random() * 70;
}

function startHold(){
  hold = true;
  if(!running && !gameOver){
    startGame();
    return;
  }
  if(gameOver){
    resetGame();
    return;
  }
  if(pigeon.y >= GROUND - 44){
    pigeon.vy = JUMP_POWER;
    pigeon.flapBoost = 1;
    jumpSound();
    flapWhisper();
  }
}

function endHold(){
  hold = false;
}

function collide(a,b){
  return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y;
}

function updateMusic(){
  if(!musicEnabled || !musicNodes || !running) return;
  musicPulse += 1;
  if(musicPulse % 240 === 0){
    const t = audioCtx.currentTime;
    const seq = [
      [196,246.94,293.66],
      [174.61,220,261.63],
      [220,261.63,329.63],
      [196,233.08,293.66]
    ];
    const chord = seq[Math.floor((musicPulse / 240) % seq.length)];
    musicNodes.pad1.frequency.setTargetAtTime(chord[0], t, 0.35);
    musicNodes.pad2.frequency.setTargetAtTime(chord[1], t, 0.35);
    musicNodes.pad3.frequency.setTargetAtTime(chord[2], t, 0.35);
  }
}

function update(){
  updateMusic();

  clouds.forEach(c => {
    c.x -= 0.18 * c.s;
    if(c.x < -130){
      c.x = WIDTH + Math.random() * 120;
      c.y = 40 + Math.random() * 70;
      c.s = 0.75 + Math.random() * 0.7;
    }
  });

  if(!running){
    pigeon.headPhase += 0.035;
    pigeon.runPhase += 0.05;
    return;
  }

  frame++;
  if(frame % 10 === 0){
    score++;
    scoreEl.textContent = score;
  }

  speed += SPEED_GAIN;
  midOffset = (midOffset + speed * 0.28) % 1200;
  nearOffset = (nearOffset + speed * 0.52) % 1400;
  groundOffset = (groundOffset + speed) % 72;

  obstacleTimer--;
  if(obstacleTimer <= 0) spawnObstacle();

  let gravity = NORMAL_GRAVITY;
  if(hold && pigeon.y < GROUND - 44 && pigeon.vy > -1.6){
    gravity = GLIDE_GRAVITY;
    pigeon.vy += FLAP_LIFT;
    if(pigeon.vy > MAX_GLIDE_FALL) pigeon.vy = MAX_GLIDE_FALL;
  }

  pigeon.vy += gravity;
  pigeon.y += pigeon.vy;

  if(pigeon.y > GROUND - 44){
    pigeon.y = GROUND - 44;
    pigeon.vy = 0;
  }

  const airborne = pigeon.y < GROUND - 44;
  pigeon.wingPhase += airborne ? (hold ? 0.45 : 0.26) : 0.16 + speed * 0.02;
  pigeon.headPhase += airborne ? 0.14 : 0.09 + speed * 0.015;
  pigeon.runPhase += 0.18 + speed * 0.03;

  const targetTilt =
    hold && airborne ? -0.18 :
    pigeon.vy < -2 ? -0.32 :
    pigeon.vy > 2 ? 0.22 : 0;
  pigeon.tilt += (targetTilt - pigeon.tilt) * 0.18;
  pigeon.flapBoost *= 0.88;

  for(let i = obstacles.length - 1; i >= 0; i--){
    obstacles[i].x -= speed;
    if(obstacles[i].x < -80) obstacles.splice(i,1);
  }

  const hitbox = {
    x: pigeon.x - 4,
    y: pigeon.y + 6,
    w: 54,
    h: 34
  };

  for(const o of obstacles){
    if(collide(hitbox, o)){
      running = false;
      gameOver = true;
      hold = false;
      flash = 8;
      if(score > best){
        best = score;
        localStorage.setItem('tauben_deluxe_best', String(best));
        bestEl.textContent = best;
      }
      showGameOverPanel();
      break;
    }
  }
  if(flash > 0) flash--;
}

function drawCloud(x,y,s){
  ctx.save();
  ctx.translate(x,y);
  ctx.scale(s,s);
  ctx.fillStyle = 'rgba(255,255,255,0.96)';
  ctx.beginPath(); ctx.ellipse(0,18,30,18,0,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(26,18,24,16,0,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(-22,22,22,14,0,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(2,8,18,14,0,0,Math.PI*2); ctx.fill();
  ctx.restore();
}

function drawBuildingLayer(buildings, offset, alpha, body, windowColor, yBase){
  ctx.save();
  ctx.globalAlpha = alpha;
  buildings.forEach(b => {
    const x = b.x - offset;
    for(const wrapX of [x, x + 1400]){
      ctx.fillStyle = body;
      ctx.fillRect(wrapX, yBase - b.h, b.w, b.h);
      ctx.fillStyle = windowColor;
      for(let row = 0; row < Math.max(2, Math.floor(b.h / 24)); row++){
        for(let col = 0; col < Math.max(2, Math.floor(b.w / 22)); col++){
          ctx.fillRect(wrapX + 9 + col * 20, yBase - b.h + 10 + row * 22, 7, 9);
        }
      }
    }
  });
  ctx.restore();
}

function drawGround(){
  ctx.fillStyle = '#7c5a43';
  ctx.fillRect(0, GROUND, WIDTH, HEIGHT - GROUND);
  ctx.fillStyle = '#8f6a49';
  ctx.fillRect(0, GROUND - 10, WIDTH, 10);

  for(let i = -2; i < 18; i++){
    const x = i * 72 - groundOffset;
    ctx.fillStyle = '#a38971';
    ctx.beginPath();
    ctx.ellipse(x + 20, GROUND + 18, 14, 4.5, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = '#8e745b';
    ctx.beginPath();
    ctx.ellipse(x + 52, GROUND + 26, 8, 3.3, 0, 0, Math.PI * 2);
    ctx.fill();
  }

  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth = 2;
  for(let i = -1; i < 16; i++){
    const x = i * 64 - (groundOffset * 1.35 % 64);
    ctx.beginPath();
    ctx.moveTo(x, GROUND + 42);
    ctx.lineTo(x + 30, GROUND + 36);
    ctx.stroke();
  }
}

function drawObstacle(o){
  ctx.save();
  ctx.translate(o.x, o.y);
  if(o.kind === 'cone'){
    ctx.fillStyle = '#f28c28';
    ctx.beginPath();
    ctx.moveTo(12,0); ctx.lineTo(24,40); ctx.lineTo(0,40);
    ctx.closePath(); ctx.fill();
    ctx.fillStyle = '#fff2d8';
    ctx.fillRect(2,12,20,5);
    ctx.fillRect(5,24,14,5);
  } else if(o.kind === 'cat'){
    ctx.fillStyle = '#232323';
    ctx.beginPath(); ctx.ellipse(24,29,20,18,0,0,Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.arc(28,12,11,0,Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.moveTo(20,4); ctx.lineTo(24,-4); ctx.lineTo(28,5); ctx.closePath(); ctx.fill();
    ctx.beginPath(); ctx.moveTo(28,5); ctx.lineTo(34,-4); ctx.lineTo(38,7); ctx.closePath(); ctx.fill();
    ctx.fillStyle = '#f2e56b';
    ctx.beginPath(); ctx.arc(25,12,1.7,0,Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.arc(31,12,1.7,0,Math.PI*2); ctx.fill();
    ctx.strokeStyle = '#232323';
    ctx.lineWidth = 4;
    ctx.lineCap = 'round';
    ctx.beginPath(); ctx.moveTo(43,28); ctx.quadraticCurveTo(53,18,49,9); ctx.stroke();
  } else {
    ctx.fillStyle = '#26313c';
    ctx.fillRect(0,8,36,24);
    ctx.fillStyle = '#4a5560';
    ctx.fillRect(5,4,26,9);
    ctx.fillStyle = '#6e7882';
    [[10,18],[18,22],[27,17]].forEach(([x,y]) => {
      ctx.beginPath(); ctx.arc(x,y,2.2,0,Math.PI*2); ctx.fill();
    });
  }
  ctx.restore();
}

function drawPigeon(){
  const x = pigeon.x;
  const y = pigeon.y + Math.sin(pigeon.runPhase) * (pigeon.y >= GROUND - 44 ? 0.9 : 0.3);
  const wing = Math.sin(pigeon.wingPhase) * (hold ? 1.15 : 0.8) + pigeon.flapBoost * 0.45;
  const headWobble = Math.sin(pigeon.headPhase) * 0.08;
  const legPhase = Math.sin(pigeon.runPhase * 1.35);
  const airborne = pigeon.y < GROUND - 44;

  ctx.save();
  ctx.translate(x + 23, y + 24);
  ctx.rotate(pigeon.tilt);

  ctx.fillStyle = '#6d7a87';
  ctx.beginPath();
  ctx.moveTo(-8, 2);
  ctx.quadraticCurveTo(-22, -10, -16, -26);
  ctx.strokeStyle = '#6d7a87';
  ctx.lineWidth = 7;
  ctx.lineCap = 'round';
  ctx.stroke();

  ctx.fillStyle = '#8f99a4';
  ctx.beginPath();
  ctx.ellipse(0, 4, 21, 14, 0, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = '#bcc3ca';
  ctx.beginPath();
  ctx.ellipse(3, 0, 14, 10, 0, 0, Math.PI * 2);
  ctx.fill();

  ctx.save();
  ctx.translate(-3, 1);
  ctx.rotate(-0.45 + wing * 0.52);
  ctx.fillStyle = '#717d89';
  ctx.beginPath();
  ctx.ellipse(-5, 0, 14, 7, -0.2, 0, Math.PI * 2);
  ctx.fill();
  ctx.restore();

  ctx.save();
  ctx.translate(17, -11);
  ctx.rotate(headWobble);
  ctx.fillStyle = '#8f99a4';
  ctx.beginPath();
  ctx.arc(0, 0, 10, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = '#111';
  ctx.beginPath();
